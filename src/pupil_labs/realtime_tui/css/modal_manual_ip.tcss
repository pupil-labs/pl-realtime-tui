 ManualIpModal { align: center middle; }
    #dialog {
        grid-size: 2;
        grid-gutter: 1 2;
        grid-rows: auto auto auto;
        padding: 0 1;
        width: 60;
        height: auto;
        border: thick $background 80%;
        background: $surface;
    }
    #question { column-span: 2; height: 1fr; width: 1fr; content-align: center middle; }
    #ip_input { column-span: 2; width: 1fr; }
    Button { width: 100%; }
